{
  "env": {
    "CLAUDE_CODE_NO_FLICKER": "1"
  },
  "showThinkingSummaries": true,
  "statusLine": {
    "type": "command",
    "command": ".claude/statusline.sh"
  },
  "permissions": {
    "defaultMode": "auto"
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/afplay /System/Library/Sounds/Glass.aiff"
          }
        ]
      }
    ]
  }
}
